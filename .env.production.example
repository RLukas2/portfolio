# =============================================================================
# PRODUCTION ENVIRONMENT
# =============================================================================
# Configuration for production deployment (Vercel, etc.)
# Set these in your hosting platform's environment variables
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED IN PRODUCTION
# -----------------------------------------------------------------------------

# Application URL (your production domain)
VITE_APP_URL=https://yourdomain.com

# Database (Production PostgreSQL - e.g., Vercel Postgres, Supabase, Neon)
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# Authentication Secret (MUST be secure in production!)
# Generate with: openssl rand -hex 64
BETTER_AUTH_SECRET=your-production-secret-here

# Auth URL (should match VITE_APP_URL)
BETTER_AUTH_URL=https://yourdomain.com

# IP Address Salt (for anonymous tracking)
# Generate with: openssl rand -hex 32
IP_ADDRESS_SALT=your-production-salt-here

# -----------------------------------------------------------------------------
# RECOMMENDED IN PRODUCTION
# -----------------------------------------------------------------------------

# Error Tracking (Sentry)
# REQUIRED for production error monitoring
# Get DSN from: Sentry Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Optional: For uploading source maps (helps with debugging)
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project

# File Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Email (Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_API_KEY=your-resend-api-key

# -----------------------------------------------------------------------------
# OAUTH PROVIDERS (if using social login)
# -----------------------------------------------------------------------------
# Update callback URLs to: https://yourdomain.com/api/auth/callback/<provider>

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# -----------------------------------------------------------------------------
# OPTIONAL INTEGRATIONS
# -----------------------------------------------------------------------------

# GitHub Stats
GITHUB_USERNAME=your-github-username
GITHUB_ACCESS_TOKEN=your-github-token

# Analytics (PostHog)
VITE_POSTHOG_KEY=your-posthog-key
VITE_POSTHOG_HOST=https://us.i.posthog.com

# AI Features (OpenAI)
OPENAI_API_KEY=your-openai-api-key

# Bookmarks (Raindrop.io)
RAINDROP_ACCESS_TOKEN=your-raindrop-token

# Scheduling (Calendly)
CALENDLY_URL=https://calendly.com/your-username

# Dashboard URL (if separate deployment)
VITE_DASHBOARD_URL=https://dashboard.yourdomain.com

# -----------------------------------------------------------------------------
# VERCEL SPECIFIC (Auto-injected, no need to set)
# -----------------------------------------------------------------------------
# VERCEL=1
# VERCEL_URL=your-app.vercel.app
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=abc123
