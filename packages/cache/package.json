{
  "name": "@xbrk/cache",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./headers": {
      "types": "./dist/headers.d.ts",
      "default": "./src/headers.ts"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "default": "./src/redis.ts"
    },
    "./keys": {
      "types": "./dist/keys.d.ts",
      "default": "./src/keys.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache dist node_modules",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@xbrk/tsconfig": "workspace:*",
    "typescript": "catalog:"
  }
}
