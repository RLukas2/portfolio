{
  "name": "@xbrk/db",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./dist/src/schema/index.d.ts",
      "default": "./src/schema/index.ts"
    },
    "./api-schemas": {
      "types": "./dist/src/api-schemas/index.d.ts",
      "default": "./src/api-schemas/index.ts"
    },
    "./env": "./env.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache dist node_modules",
    "dev": "tsc --watch",
    "db:push": "dotenv -e ../../.env -- pnpm exec drizzle-kit push",
    "db:studio": "dotenv -e ../../.env -- pnpm exec drizzle-kit studio",
    "db:generate": "dotenv -e ../../.env -- pnpm exec drizzle-kit generate",
    "db:migrate": "dotenv -e ../../.env -- pnpm exec tsx src/migrate.ts",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@t3-oss/env-core": "catalog:",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "ws": "^8.18.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "@xbrk/tsconfig": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
