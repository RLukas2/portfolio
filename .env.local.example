# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# This file contains minimal configuration for local development
# Copy to .env.local for quick setup
# =============================================================================

# Application
VITE_APP_URL=http://localhost:3000
VITE_DASHBOARD_URL=http://localhost:3002
NODE_ENV=development

# Database (Local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio

# Authentication
BETTER_AUTH_SECRET=dev-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:3000

# Security
IP_ADDRESS_SALT=dev-salt-change-in-production

# GitHub (for stats)
GITHUB_USERNAME=your-github-username

# Error Tracking (Sentry) - Optional for local dev
# VITE_SENTRY_DSN=

# Optional: Add OAuth providers if testing auth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
